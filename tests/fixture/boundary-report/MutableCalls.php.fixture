<?php

declare(strict_types=1);

$date = new \DateTime('2026-01-01');
date_modify($date, '+1 day');

$direct = date_add(new \DateTime('2026-02-01'), new \DateInterval('P1D'));

function localAcceptsDate(\DateTime $date): void
{
}

localAcceptsDate(new \DateTime('2026-03-01'));

date_modify(modifier: '+1 day', object: $date);

interface StableMutableApi
{
    public function accept(\DateTime $date): void;

    public function acceptMany(\DateTime ...$dates): void;

    public static function acceptStatic(\DateTime $date): void;
}

final class MutableApi implements StableMutableApi
{
    public function accept(\DateTime $date): void
    {
    }

    public function acceptMany(\DateTime ...$dates): void
    {
    }

    public static function acceptStatic(\DateTime $date): void
    {
    }
}

$api = new MutableApi();
$api->accept(new \DateTime('2026-04-01'));
$api->acceptMany(new \DateTime('2026-05-01'), new \DateTime('2026-06-01'));
MutableApi::acceptStatic(new \DateTime('2026-07-01'));

interface StableMutableFactory
{
    public function __construct(\DateTime $date);
}

final class MutableFactory implements StableMutableFactory
{
    public function __construct(\DateTime $date)
    {
    }
}

$factory = new MutableFactory(new \DateTime('2026-08-01'));

/** @mutable-datetime */
function markedMutableCall(\DateTime $date): void
{
}

markedMutableCall(new \DateTime('2026-09-01'));
