<?php

declare(strict_types=1);

namespace App\Docs;

use Doctrine\ORM\Mapping as ORM;

final class DocblockSynced
{
    /** @var \DateTime|null the last run marker */
    private ?\DateTime $lastRun = null;

    /** @var \DateTime kept by the ORM */
    #[ORM\Column(type: 'datetime')]
    private \DateTime $storedAt;

    /** @var \DateTime docblock-only declaration stays */
    private $legacy;

    /**
     * @param \DateTime $from lower bound
     * @param string $label
     *
     * @return \DateTime
     */
    public function window(\DateTime $from, string $label): \DateTime
    {
        $this->lastRun = new \DateTime('now');

        return $from;
    }
}
