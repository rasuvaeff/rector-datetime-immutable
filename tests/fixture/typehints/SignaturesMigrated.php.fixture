<?php

declare(strict_types=1);

final class Scheduler
{
    private \DateTime $lastRun;
    private ?\DateTime $nextRun = null;

    public function __construct(
        private \DateTime $createdAt,
    ) {
        $this->lastRun = new \DateTime();
    }

    public function reschedule(\DateTime $when): \DateTime|false
    {
        $this->nextRun = $when;

        return $this->lastRun;
    }
}

function firstOf(\DateTime $candidate, ?\DateTime $fallback): ?\DateTime
{
    return $fallback ?? $candidate;
}
