<?php

declare(strict_types=1);

abstract class BaseEvent
{
    public \DateTime $at;
}

final class ChildEvent extends BaseEvent
{
    public \DateTime $at;
    private \DateTimeImmutable $own;
}

abstract class BasePromoted
{
    protected \DateTime $placedAt;
}

final class ChildPromoted extends BasePromoted
{
    private \DateTimeImmutable $own;

    public function __construct(
        protected \DateTime $placedAt,
    ) {
    }
}
