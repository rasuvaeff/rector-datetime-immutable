<?php

declare(strict_types=1);

final class LegacyBridge
{
    /**
     * @mutable-datetime
     */
    private \DateTime $raw;

    private \DateTime $converted;

    /**
     * @mutable-datetime
     */
    public function touch(\DateTime $when): \DateTime
    {
        return $when;
    }

    public function convert(\DateTime $when): \DateTime
    {
        return $when;
    }
}

/**
 * @mutable-datetime
 */
function legacyNow(\DateTime $seed): \DateTime
{
    return $seed;
}
